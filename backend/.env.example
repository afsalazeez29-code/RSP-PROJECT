NODE_ENV=production
PORT=4000
APP_NAME=Recipe.IO Backend

MONGODB_URI=
MONGODB_CONNECT_RETRIES=3
MONGODB_CONNECT_RETRY_DELAY=2000

JWT_SECRET=change-this-to-a-random-64-char-string
COOKIE_SECRET=change-this-to-another-random-64-char-string
BCRYPT_SALT_ROUNDS=10

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

FRONTEND_ORIGIN=https://your-app.vercel.app
BACKEND_URL=https://your-domain.duckdns.org

ITEMS_PER_PAGE=10
RECIPES_PER_PAGE=10
USERS_PER_PAGE=10
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
